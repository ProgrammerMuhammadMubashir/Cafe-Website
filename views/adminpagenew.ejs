<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Admin Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="adminpagenew.css">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
        <style>

        </style>
</head>

<body>

    <!-- Decorative ambient background layer (purely visual) -->
    <div class="ambient-glow ambient-glow--one"></div>
    <div class="ambient-glow ambient-glow--two"></div>
    <div class="ambient-grain"></div>

    <div class="admin-shell">

        <!-- Brand header (new, purely presentational) -->
        <header class="admin-brand-header" data-aos="fade-down" data-aos-duration="700">
            <div class="brand-mark">
                <span class="brand-icon"><i class="fa-solid fa-mug-saucer"></i></span>
                <div class="brand-text">
                    <h1 class="brand-title">Mubashir&nbsp; Cafe</h1>
                    <p class="brand-subtitle">Café &amp; Reservation Management</p>
                </div>
            </div>
            <div class="brand-chip">
                <i class="fa-regular fa-clock"></i>
                <span>Live Console</span>
            </div>
        </header>

        <ul class="nav nav-tabs d-flex justify-content-around p-1 navclassforjs luxury-tab-nav" id="myTab" role="tablist"
            style="background-color: var(--primarycolor--);">
            <li class="nav-item" role="presentation">
                <button class="nav-link active  text-light bg-success btnofnavinadmin luxury-tab-btn" id="home-tab" data-bs-toggle="tab"
                    data-bs-target="#home-tab-pane" type="button" role="tab" aria-controls="home-tab-pane"
                    aria-selected="true"><i class="fa-solid fa-gauge-high tab-icon"></i>Main Dashboard</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link text-light bg-success btnofnavinadmin luxury-tab-btn" id="profile-tab" data-bs-toggle="tab"
                    data-bs-target="#profile-tab-pane" type="button" role="tab" aria-controls="profile-tab-pane"
                    aria-selected="false"><i class="fa-solid fa-receipt tab-icon"></i>Orders</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link text-light bg-success btnofnavinadmin luxury-tab-btn" id="contact-tab" data-bs-toggle="tab"
                    data-bs-target="#contact-tab-pane" type="button" role="tab" aria-controls="contact-tab-pane"
                    aria-selected="false"><i class="fa-solid fa-gear tab-icon"></i>Setting</button>
            </li>

        </ul>
        <div class="tab-content admin-main" id="myTabContent" style="color: var(--secondarycolor--);">
            <div class="tab-pane fade show active admin-panel" id="home-tab-pane" role="tabpanel" aria-labelledby="home-tab"
                tabindex="0" id="dashboardcontainer">
                <!--Dashboard content-->
                <div class="panel-inner">

                    <div class="welcome-block" data-aos="fade-up" data-aos-duration="700">
                        <h1 id="welcomeheading">Welcome Admin!</h1>
                        <span id="welcomedisc">Manage, monitor, and control all aspects of your platform with ease</span>
                    </div>

                    <div id="percentstatistics" class="d-flex flex-row justify-content-around m-5 stats-row">
                        <div class="stat-card" data-aos="zoom-out-down" data-aos-duration="1000">
                            <i class="fa-solid fa-arrow-trend-up stat-icon stat-icon--success"></i>
                            <span class="text-success">75%</span>
                            <div class="stat-description">Interaction This Week</div>
                        </div>
                        <div class="stat-card" data-aos="zoom-out-down" data-aos-duration="1000">
                            <i class="fa-solid fa-arrow-trend-down stat-icon stat-icon--danger"></i>
                            <span class="text-danger">12%</span>
                            <div class="stat-description">Decline This Week</div>
                        </div>
                        <div class="stat-card" data-aos="zoom-out-down" data-aos-duration="1000">
                            <i class="fa-solid fa-mug-hot stat-icon stat-icon--gold"></i>
                            <span class="text-success">320</span>
                            <div class="stat-description">Orders This Week</div>
                        </div>
                    </div>

                    <div id="graphical-representation" class="chart-card" data-aos="fade-up" data-aos-duration="800">
                        <canvas id="myChart" style="width:100%;max-width:700px" class="mx-auto"></canvas>
                    </div>
                    <span id="spanof-chart">Monthly orders graph</span>

                    <h2 id="feedback-heading"><i class="fa-solid fa-comments heading-icon"></i>Feedback by users</h2>
                    <div id="feedback" class="ms-5 mx-5 feedback-card" data-aos="fade-up" data-aos-duration="800">
                        <ol>
                            <% arrayoffeedback.forEach((obj) => { %>
                                <li class="feedbackli"><%= obj.feedback %> ( <%= obj.nameofgiver %> )</li>
                              <% }) %>
                        </ol>
                        <span id="msgaboutfeedback-two"></span>
                        <form action="/admindashboard/clearfeedbacks" method="post" id="feedbackform">
                            <button type="submit" id="clearfeedbacks-btn"><i class="fa-solid fa-broom"></i> Clear all</button>
                        </form>
                    </div>

                </div>
            </div>
            <div class="tab-pane fade admin-panel" id="profile-tab-pane" role="tabpanel" aria-labelledby="profile-tab" tabindex="0">
                <div class="panel-inner">

                    <div id="totalstats-orders">
                        <span id="communalspan" class="seating-stat">
                            <i class="fa-solid fa-users seating-stat-icon"></i>
                            <%= recommunal %> out of <%= tcommunal %> Communal sitting plans has reserved
                            <% if (recommunal === tcommunal) { %>
                              <span class="all-reserved-tag">(All reserved)</span>
                              <% %>
                            <% } %>
                          </span>

                        <span id="tableandchairspan" class="seating-stat">
                            <i class="fa-solid fa-chair seating-stat-icon"></i>
                            <%= retableandchair %> out of <%= ttableandchair %> Table and Chair sitting plans has reserved
                        <% if(retableandchair===ttableandchair){ %>
                            <span class="all-reserved-tag">(All reserved)</span>
                        <% }%>

                        </span>
                        <span id="boothspan" class="seating-stat">
                            <i class="fa-solid fa-couch seating-stat-icon"></i>
                            <%= rebooth %> out of <%= tbooth %> Booth sitting plans has reserved
                            <% if(rebooth===tbooth){ %>
                                <span class="all-reserved-tag">(All reserved)</span>
                            <% }%>
                        </span>
                    </div>

                    <!--Custom modal for handling orders-->

                    <div id="customModal" class="modal">
                        <div class="modal-content luxury-modal-content">
                          <span id="closeModalBtn" class="close">&times;</span>
                          <h3 class="modal-title"><i class="fa-solid fa-envelope-circle-check"></i> Accept Reservation</h3>
                          <form id="reservationEditForm" method="post"  action="/admindashboard">
                            <div class="form-field">
                                <label for="fullName">Full Name:</label>
                                <input type="text" id="fullName" name="fullName" required>
                            </div>

                            <div class="form-field">
                                <label for="email">Email:</label>
                                <input type="email" id="email" name="email" required>
                            </div>

                            <div class="form-field">
                                <label for="phone">Phone:</label>
                                <input type="tel" id="phone" name="phone" required>
                            </div>

                            <div class="form-field">
                                <label for="date">Date:</label>
                                <input type="date" id="date" name="date" required>
                            </div>

                            <div class="form-field">
                                <label for="time">Time:</label>
                                <input type="time" id="time" name="time" required>
                            </div>

                            <div class="form-field">
                                <label for="duration">Duration:</label>
                                <input type="number" id="duration" name="duration" min="1" required> hours
                            </div>

                            <div class="form-field">
                                <label for="numberOfGuests">Number of Guests:</label>
                                <input type="number" id="numberOfGuests" name="numberOfGuests" min="1" required>
                            </div>

                            <div class="form-field">
                                <label for="seatingPlan">Seating Plan:</label>
                                <select id="seatingPlan" name="seatingPlan" required>
                                  <option value="booth">Booth</option>
                                  <option value="tableandchair">Table and Chair</option>
                                  <option value="communal">Communal</option>
                                </select>
                            </div>

                            <textarea name="discoforderbyadmin" id="discoforder-byadmin"  spellcheck="false" placeholder="Write a personal note to include in the acceptance email...">

                            </textarea>
                            <button type="submit" id="sendmailbtn-modal"><i class="fa-solid fa-paper-plane"></i> Send mail</button>
                          </form>

                        </div>
                      </div>

                    <div id="customModal2" class="modal">
                        <div class="modal-content luxury-modal-content">
                          <span id="closeModalBtn2" class="close">&times;</span>
                          <h3 class="modal-title"><i class="fa-solid fa-circle-xmark"></i> Decline Reservation</h3>

                          <form id="reservationdeclineform" method="post"  action="/admindashboard/declineorder">
                              <input type="hidden" name="emailtodecline"  id="emailtodecline">
                            <textarea name="discoforderbyadmin" id="discoforder-byadmin"  spellcheck="true" placeholder="Write a personal note to include in the decline email...">
                            </textarea>
                            <button type="submit" id="sendmailbtn-modal"><i class="fa-solid fa-paper-plane"></i> Send mail</button>
                          </form>

                        </div>
                      </div>


                    <div id="allorders-customer">

                        <% arrayofreservations.forEach((reservation) => { %>
                            <div class="orderofcustomer" data-aos="fade-up" data-aos-duration="600">
                              <div><b><span>Full Name:</span></b><span class="fullName"> <%= reservation.fullName %></span></div>
                              <div><b><span class="email">Email:</span></b><span> <%= reservation.email %></span></div>
                              <div><b><span class="phone">Phone:</span></b><span> <%= reservation.phone %></span></div>
                              <div><b><span class="date">Date:</span></b> <span><%= reservation.date %></span></div>
                              <div><b><span class="time">Time:</span></b> <span><%= reservation.time %></span></div>
                              <div><b><span class="duration">Duration:</span></b><span> <%= reservation.duration %></span></div>
                              <div><b><span class="numberOfGuests">Number of Guests:</span></b><span> <%= reservation.numberOfGuests %></span></div>
                              <div><b><span class="seatingPlan">Seating Plan:</span></b><span> <%= reservation.seatingPlan %></span></div>
                              <div class="orderofcustomer-button-container">
                                <% if (!reservation.mailsent) { %>

                                  <span><button class="acceptorder openModalBtn"><i class="fa-solid fa-check"></i> Accept</button></span>
                                  <span><button class="declineorder openModalBtn2" type="submit"><i class="fa-solid fa-xmark"></i> Decline</button></span>

                                <% } else { %>
                                    <form action="/admindashboard/removeorder" method="post" class="d-flex justify-content-around" style="width:100%;">
                                        <input type="hidden" name="emailtoremove" value="<%= reservation.email %>">
                                  <span><button class="acceptedorder" style="opacity: 0.5;" disabled><i class="fa-solid fa-check-double"></i> Accepted</button></span>
                                  <span><button class="removeorder " type="submit" ><i class="fa-solid fa-trash"></i> Remove</button></span>
                                </form>
                                <% } %>
                              </div>
                            </div>
                          <% }) %>




                    </div>
                </div>
            </div>
            <div class="tab-pane fade admin-panel" id="contact-tab-pane" role="tabpanel" aria-labelledby="contact-tab" tabindex="0">
                <div class="panel-inner">
                    <h3 id="settingheading"><i class="fa-solid fa-sliders"></i> Setting</h3>
                    <div id="allsetting-container">
                        <div class="form-check form-switch settings-card" id="allowdark-mode">
                            <label class="form-check-label" for="flexSwitchCheck-darkmode"><i class="fa-solid fa-moon"></i> Dark mode</label>
                            <input class="form-check-input" type="checkbox" id="flexSwitchCheck-darkmode">
                        </div>


                        <div id="update-numbers" class="d-flex flex-column settings-card">
                            <h5 class="mt-3"><i class="fa-solid fa-chair"></i> Update</h5>
                            <form action="/admindashboard/updatetotalnumber" method="post" class="d-flex flex-column">
                                <div class="form-field">
                                    <label for="Communalnumber"> Communal </label>
                                    <input type="number" id="Communalnumber"  value="<%= `${tcommunal}` %>" name="communalupdated"  min="<%= `${recommunal}` %>" required>
                                </div>

                                <div class="form-field">
                                    <label for="TableandChairnumber"> Chair and Table </label>
                                    <input type="number" id="TableandChairnumber" value="<%= `${ttableandchair}` %>" name="tableandchairupdated"  min="<%= `${retableandchair}` %>" required>
                                </div>

                                <div class="form-field">
                                    <label for="Boothnumber"> Booth </label>
                                    <input type="number" id="Boothnumber" value="<%= `${tbooth}` %>" name="boothupdated"  min="<%= `${rebooth}` %>" required>
                                </div>
                               <input type="submit" value="Update total numbers" id="submitbtnofupdate" >
                            </form>
                        </div>

                    </div>
                </div>
            </div>


            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
            <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.9.4/Chart.js">
            </script>
            <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
            <script src="adminpage.js"></script>


            <script>


                AOS.init({
                    disable: false,
                    startEvent: 'DOMContentLoaded',
                    initClassName: 'aos-init',
                    animatedClassName: 'aos-animate',
                    useClassNames: false,
                    disableMutationObserver: false,
                    debounceDelay: 50,
                    throttleDelay: 99,

                    offset: 120,
                    delay: 0,
                    duration: 400,
                    easing: 'ease',
                    once: false,
                    mirror: false,
                    anchorPlacement: 'top-bottom',
                });
            </script>
        </div>
    </div>
</body>

</html>
