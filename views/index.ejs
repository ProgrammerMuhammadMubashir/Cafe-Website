<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Mubashir Café | The Place of Joy</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Playfair+Display:wght@500;600;700;800&family=Dancing+Script:wght@600;700&display=swap" rel="stylesheet">

    <!-- Global Styles -->
    <link rel="stylesheet" href="global.css">

    <!-- Homepage Styles -->
    <link rel="stylesheet" href="index.css">
</head>

<body>

    <!-- ==================================================
                        HEADER
    =================================================== -->

    <header class="global-header">

        <div class="global-header-container">

            <div class="global-logo-area">

                <img src="resources/icon.png"
                     alt="Mubashir Café Logo"
                     class="global-logo">

                <h1 class="global-logo-title">
                    Mubashir Café
                </h1>

            </div>

            <img src="resources/menuicon.webp"
                 alt="Menu"
                 id="menu-icon"
                 class="global-menu-icon">

            <nav class="global-navbar" id="navofindex">

                <ul class="global-nav-list">

                    <li><a href="/mainpage" class="global-nav-link">Home</a></li>

                    <li><a href="/menu" class="global-nav-link">Menu</a></li>

                    <li><a href="/onlinereservation" class="global-nav-link">Reservation</a></li>

                    <li><a href="/contactus" class="global-nav-link">Contact</a></li>

                </ul>

            </nav>

        </div>

        <!-- Mobile Navigation -->

        <div id="navofindexmobile"
             class="displaynone global-mobile-nav">

            <ul class="global-mobile-nav-list">

                <li><a href="/mainpage">Home</a></li>

                <li><a href="/menu">Menu</a></li>

                <li><a href="/onlinereservation">Reservation</a></li>

                <li><a href="/contactus">Contact</a></li>

            </ul>

        </div>

    </header>



    <!-- ==================================================
                        MAIN
    =================================================== -->

    <main class="idx-main">

        <!-- Hero Section -->

        <section class="idx-hero">

            <img src="resources/herosectionimg.jpg"
                 alt="Coffee Hero"
                 id="herosection-img"
                 class="idx-hero-image">

            <div class="idx-hero-overlay"></div>

            <div class="idx-hero-content">

                <p class="idx-hero-subtitle">

                    Welcome To

                </p>

                <h1 class="idx-hero-title">

                    Mubashir Café

                </h1>

                <span id="quote"
                      class="idx-hero-quote">

                </span>

                <p class="idx-hero-description">

                    Every cup tells a story.
                    Experience handcrafted coffee, delicious desserts,
                    and a peaceful atmosphere made for unforgettable memories.

                </p>

                <a href="/onlinereservation">

                    <button id="herosection-button"
                            class="primary-btn">

                        Reserve Your Table →

                    </button>

                </a>

            </div>

        </section>



        <!-- Hot Items -->

        <section class="idx-section">

            <div class="idx-section-heading">

                <h2 class="idx-section-title">

                    Our Hot Picks

                </h2>

                <p class="idx-section-subtitle">

                    Freshly brewed favourites loved by our customers.

                </p>

            </div>


            <div class="idx-hot-items">

                <article class="idx-hot-card">

                    <img src="resources/americano-coffee.jpg"
                         alt="Americano"
                         class="idx-hot-card-image">

                    <div class="idx-hot-card-content">

                        <h3 class="idx-hot-card-title">

                            Café Americano

                        </h3>

                        <p class="idx-hot-card-description">

                            Strong, bold and aromatic coffee crafted
                            from premium roasted beans.

                        </p>

                        <span class="idx-hot-card-price">

                            $10

                        </span>

                    </div>

                </article>



                <article class="idx-hot-card">

                    <img src="resources/flatwhite-coffee.jpg"
                         alt="Flat White"
                         class="idx-hot-card-image">

                    <div class="idx-hot-card-content">

                        <h3 class="idx-hot-card-title">

                            Flat White

                        </h3>

                        <p class="idx-hot-card-description">

                            Rich espresso blended with silky steamed milk
                            for the perfect balance.

                        </p>

                        <span class="idx-hot-card-price">

                            $20

                        </span>

                    </div>

                </article>



                <article class="idx-hot-card">

                    <img src="resources/iced-coffee.jpg"
                         alt="Iced Coffee"
                         class="idx-hot-card-image">

                    <div class="idx-hot-card-content">

                        <h3 class="idx-hot-card-title">

                            Iced Coffee

                        </h3>

                        <p class="idx-hot-card-description">

                            Refreshing chilled coffee served to energize
                            every single moment.

                        </p>

                        <span class="idx-hot-card-price">

                            $30

                        </span>

                    </div>

                </article>

            </div>

        </section>



        <!-- Features -->

        <section class="idx-section">

            <div class="idx-section-heading">

                <h2 class="idx-section-title">

                    Why Choose Us

                </h2>

                <p class="idx-section-subtitle">

                    More than just coffee.

                </p>

            </div>


            <div class="idx-features-container">

                <article class="idx-feature-card">

                    <img src="resources/qualitypic.jpg"
                         alt="Premium Ingredients"
                         class="idx-feature-image">

                    <div class="idx-feature-content">

                        <h3 class="idx-feature-title">

                            Premium Ingredients

                        </h3>

                        <p class="idx-feature-description">

                            Every bean and ingredient is carefully selected
                            to ensure exceptional taste and unforgettable quality.

                        </p>

                    </div>

                </article>



                <article class="idx-feature-card idx-feature-reverse">

                    <img src="resources/calmpic.jpg"
                         alt="Peaceful Environment"
                         class="idx-feature-image">

                    <div class="idx-feature-content">

                        <h3 class="idx-feature-title">

                            Peaceful Environment

                        </h3>

                        <p class="idx-feature-description">

                            Relax, study, work or enjoy quality time
                            in a warm and calming atmosphere.

                        </p>

                    </div>

                </article>



                <article class="idx-feature-card">

                    <img src="resources/servicepic.jpg"
                         alt="Exceptional Service"
                         class="idx-feature-image">

                    <div class="idx-feature-content">

                        <h3 class="idx-feature-title">

                            Exceptional Service

                        </h3>

                        <p class="idx-feature-description">

                            Our friendly staff ensures every customer
                            leaves with a smile and a memorable experience.

                        </p>

                    </div>

                </article>

            </div>

        </section>

    </main>



    <!-- ==================================================
                        FOOTER
    =================================================== -->

    <footer class="global-footer">

        <div class="global-footer-container">

            <p class="global-footer-text">

                © 2026 Mubashir Café. Crafted with passion by Muhammad Mubashir.

            </p>

            <a href="/adminlogin"
               class="global-admin-btn"
               title="Admin Login">

                ⚙

            </a>

        </div>

    </footer>


    <script src="script.js"></script>

</body>
</html>